# Optional: API keys are normally stored in keys.json (prompted on first run).
# You may still set MEXC/Binance keys here as a fallback.

# ─── Binance → MEXC futures (BTC/USDT:USDT) ─────────────────────────
FUTURES_SYMBOL=BTC/USDT:USDT
SIGNAL_EXCHANGE=binance
EXECUTION_EXCHANGE=mexc
LARGE_ORDER_THRESHOLD_BTC=5.0
ORDER_TTL_SECONDS=3.0

# ─── Risk management ─────────────────────────────────────────────────
MAX_POSITION_USDT=500
MAX_DAILY_LOSS_USDT=100
CIRCUIT_BREAKER_LOSSES=3

# ─── Telegram (optional) ───────────────────────────────────────────────
ENABLE_TELEGRAM=false
TELEGRAM_API_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Runtime ─────────────────────────────────────────────────────────
PYTHON_COMMAND=python3
ENABLE_CTRL_C_HANDLING=false
