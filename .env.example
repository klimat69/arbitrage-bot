# ─── Exchange API keys ───────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET=
MEXC_API_KEY=
MEXC_SECRET=

# Optional: other exchanges supported by the framework
KUCOIN_API_KEY=
KUCOIN_SECRET=
KUCOIN_PASSPHRASE=

# ─── Binance → MEXC strategy ────────────────────────────────────────
SIGNAL_EXCHANGE=binance          # Order book signals source
EXECUTION_EXCHANGE=mexc          # Trade execution target
LARGE_ORDER_THRESHOLD_BTC=5.0    # Min order size (BTC equivalent) to track
ORDER_TTL_SECONDS=3.0            # Anti-spoofing: min time order must rest (seconds)

# ─── Risk management ─────────────────────────────────────────────────
MAX_POSITION_USDT=500            # Max single/total position size per symbol
MAX_DAILY_LOSS_USDT=100          # Daily loss limit (circuit breaker)
CIRCUIT_BREAKER_LOSSES=3         # Consecutive losses before halt

# ─── Telegram notifications ──────────────────────────────────────────
ENABLE_TELEGRAM=false
TELEGRAM_API_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Licensing (required at startup, cached 24h) ─────────────────────
LICENSE_KEY=
LICENSE_SERVER_URL=https://your-license-server.example.com/api/verify

# ─── Runtime ─────────────────────────────────────────────────────────
PYTHON_COMMAND=python3
ENABLE_CTRL_C_HANDLING=false
